# EditorConfig — https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{md,markdown}]
trim_trailing_whitespace = false  # markdown uses trailing spaces for line breaks
indent_size = 2

[*.{yml,yaml,json,toml}]
indent_size = 2

[*.{cc,h,hpp,proto,cmake}]
indent_size = 2

[CMakeLists.txt]
indent_size = 2

[Makefile]
indent_style = tab
